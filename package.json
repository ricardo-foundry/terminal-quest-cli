{
  "name": "terminal-quest-cli",
  "version": "2.8.0",
  "description": "Terminal Quest - a multilingual RPG adventure that lives entirely in your terminal (npx terminal-quest-cli). Now with 3 new season-locked quests (cyber-bazaar / forgotten-archive / orbital-station), an optional TTS mode, and an in-game tutorial command.",
  "main": "src/game.js",
  "bin": {
    "terminal-quest": "./bin/terminal-quest.js",
    "tq": "./bin/terminal-quest.js",
    "adventure": "./bin/terminal-quest.js"
  },
  "preferGlobal": true,
  "files": [
    "bin/",
    "src/",
    "docs/",
    "quests/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "node bin/terminal-quest.js",
    "dev": "node bin/terminal-quest.js --dev",
    "test": "node --test test/*.test.js",
    "test:watch": "node --test --watch test/*.test.js"
  },
  "keywords": [
    "game",
    "cli",
    "terminal",
    "puzzle",
    "adventure",
    "retro",
    "rpg",
    "text-adventure",
    "interactive-fiction",
    "linux",
    "kimi-os"
  ],
  "author": "KIMI-AI <kimi@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ricardo-foundry/terminal-quest-cli.git"
  },
  "bugs": {
    "url": "https://github.com/ricardo-foundry/terminal-quest-cli/issues"
  },
  "homepage": "https://github.com/ricardo-foundry/terminal-quest-cli#readme",
  "dependencies": {
    "chalk": "^5.6.2",
    "figlet": "^1.11.0",
    "keypress": "^0.2.1"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
