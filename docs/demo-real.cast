[0.604,"o","\n\u001b[1mBasic commands:\u001b[22m\n  \u001b[92mls\u001b[39m [path]       list directory (add -a for hidden)\n  \u001b[92mcd\u001b[39m <path>       change directory (~ is home)\n  \u001b[92mcat\u001b[39m <file>      read a file\n  \u001b[92mpwd\u001b[39m             print current path\n  \u001b[92mclear\u001b[39m           clear the screen\n  \u001b[92mhelp\u001b[39m            show this help\n  \u001b[92mhint\u001b[39m            get a hint for the current quest\n"]
[0.604,"o","\n\u001b[1mRPG:\u001b[22m\n  \u001b[95mstatus\u001b[39m          show character sheet\n  \u001b[95minventory\u001b[39m       list items\n  \u001b[95muse\u001b[39m <item>      use an item\n  \u001b[95mtalk\u001b[39m <npc>      talk to an NPC\n  \u001b[95mmap\u001b[39m             world map\n  \u001b[95mquests\u001b[39m          quest log\n  \u001b[95machievements\u001b[39m    achievements\n  \u001b[95munlock\u001b[39m master   use the master key\n"]
[0.604,"o","\n\u001b[1mMeta:\u001b[22m\n  \u001b[34msave\u001b[39m [slot]         save to a named slot\n  \u001b[34mload\u001b[39m <slot>         load a slot\n  \u001b[34msaves\u001b[39m               list save slots\n  \u001b[34mtheme\u001b[39m <name>        dark | light | retro\n  \u001b[34mlang\u001b[39m <code>         en | zh\n  \u001b[34mversion\u001b[39m             show version\n  \u001b[34mexit\u001b[39m                quit the game\n\n\u001b[90m--------------------------------------------------------\u001b[39m\n\u001b[34mTips:\u001b[39m\n  * Use scan to find hidden things\n  * Talk to every NPC\n  * Explore every directory\n  * Finish quests for EXP\n  * Collect every key fragment\n\u001b[90m--------------------------------------------------------\u001b[39m\n"]
